{
	"name": "@ambiently-work/faux",
	"version": "0.0.1",
	"description": "POSIX-ish shell that runs entirely in-process — no child_process, no subshell. Virtual FS, builtins, and an optional WASM-accelerated runtime.",
	"license": "MIT",
	"author": "ambiently",
	"homepage": "https://github.com/ambiently-work/faux",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ambiently-work/faux.git"
	},
	"bugs": "https://github.com/ambiently-work/faux/issues",
	"keywords": [
		"shell",
		"bash",
		"posix",
		"sandbox",
		"virtual-filesystem",
		"wasm",
		"agent"
	],
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./wasm": "./src/wasm/index.ts",
		"./wasm-binary": "./pkg/faux_wasm_bg.wasm"
	},
	"publishConfig": {
		"access": "public",
		"main": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js",
				"default": "./dist/index.js"
			},
			"./wasm": {
				"types": "./dist/wasm/index.d.ts",
				"import": "./dist/wasm/index.js",
				"default": "./dist/wasm/index.js"
			},
			"./wasm-binary": "./pkg/faux_wasm_bg.wasm"
		}
	},
	"files": [
		"dist",
		"pkg"
	],
	"scripts": {
		"shell": "bun run cli/repl.ts",
		"wasm-demo": "bun run cli/wasm-demo.ts",
		"docs": "bun run --cwd packages/docs dev",
		"docs:build": "bun run --cwd packages/docs build",
		"docs:check": "bunx --bun --cwd packages/docs astro check",
		"build": "bun run build:wasm && bun run build:ts",
		"build:wasm": "wasm-pack build --target web --out-dir pkg",
		"build:ts": "tsc -b --force",
		"test": "bun test",
		"test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-dir=coverage",
		"check": "biome check .",
		"check:types": "tsc -b --force",
		"check:knip": "bunx knip@latest --no-progress",
		"check:publint": "bunx publint@latest",
		"check:attw": "bunx --bun @arethetypeswrong/cli@latest --pack . --ignore-rules cjs-resolves-to-esm",
		"check:md": "bunx markdownlint-cli2@latest",
		"check:rust:fmt": "cargo fmt --all -- --check",
		"check:rust:clippy": "cargo clippy --all-targets --all-features -- -D warnings",
		"check:rust:test": "cargo test --all-features",
		"format": "biome format --write .",
		"format:rust": "cargo fmt --all",
		"clean": "rm -rf dist pkg tsconfig.tsbuildinfo coverage",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@ambiently-work/mirage": "github:ambiently-work/mirage#82eed44375ba20c281ee93c6584c4549f3161796",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.0",
		"@biomejs/js-api": "^4.0.0",
		"@biomejs/wasm-nodejs": "^2.4.10",
		"quickjs-emscripten": "^0.32.0",
		"tree-sitter-wasms": "^0.1.13",
		"typescript": "^5.9.2",
		"web-tree-sitter": "0.22"
	},
	"workspaces": [
		"packages/docs"
	]
}
